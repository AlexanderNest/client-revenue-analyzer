<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-sequences-fixed" author="Alex">
        <createSequence sequenceName="client_id_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="create-table-users" author="Alex">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="users"/></not>
        </preConditions>
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="main_calendar_id" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="cancelled_calendar_id" type="VARCHAR(200)"/>
            <column name="cancelled_calendar_enabled" type="boolean" defaultValueBoolean="false"/>
            <column name="events_backup_enabled" type="boolean" defaultValueBoolean="false"/>
            <column name="role" type="VARCHAR(255)" defaultValue="USER"/>
            <column name="source" type="VARCHAR(255)" defaultValue="telegram"/>
        </createTable>
    </changeSet>


    <changeSet id="create-table-client" author="Alex">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="client"/></not>
        </preConditions>
        <createTable tableName="client">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="price_per_hour" type="INT"/>
            <column name="active" type="boolean" defaultValueBoolean="true"/>
            <column name="start_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_client_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
        </createTable>
        <createIndex tableName="client" indexName="idx_client_id">
            <column name="id"/>
        </createIndex>
    </changeSet>


    <changeSet id="client-constraints" author="Alex">
        <createIndex tableName="client" indexName="idx_unique_client_name_per_user" unique="true">
            <column name="name"/>
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="client" indexName="idx_unique_phone_per_user" unique="true">
            <column name="phone"/>
            <column name="user_id"/>
        </createIndex>
    </changeSet>


    <changeSet id="create-table-event-backup" author="Alex">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="event_backup"/></not>
        </preConditions>
        <createTable tableName="event_backup">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_backup_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="backup_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="type" type="VARCHAR(100)"/>
        </createTable>
        <createIndex tableName="event_backup" indexName="idx_event_backup_user_time">
            <column name="user_id"/>
            <column name="backup_time"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-table-event" author="Alex">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="event"/></not>
        </preConditions>
        <createTable tableName="event">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)"/>
            <column name="summary" type="VARCHAR(255)"/>
            <column name="start_date" type="TIMESTAMP"/>
            <column name="end_date" type="TIMESTAMP"/>
            <column name="event_backup_id" type="BIGINT">
                <constraints foreignKeyName="fk_event_backup" referencedTableName="event_backup" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="event_extension" type="VARCHAR(1000)"/>
        </createTable>
        <createIndex tableName="event" indexName="idx_event_backup_id">
            <column name="event_backup_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="fix-price-change-history" author="Alex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="price_change_history"/>
        </preConditions>
        <dropTable tableName="price_change_history"/>
    </changeSet>
    <changeSet id="create-table-price-history" author="Alex">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="price_change_history"/></not>
        </preConditions>
        <createTable tableName="price_change_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_price_client" referencedTableName="client" referencedColumnNames="id"/>
            </column>
            <column name="previous_price" type="INT"/>
            <column name="new_price" type="INT"/>
            <column name="change_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>